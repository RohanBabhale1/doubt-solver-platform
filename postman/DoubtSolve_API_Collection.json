        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 201\", () => pm.response.to.have.status(201));\r",
                  "pm.test(\"Token returned\", () => {\r",
                  "  const b = pm.response.json();\r",
                  "  pm.expect(b).to.have.property('token');\r",
                  "  pm.expect(b.token).to.be.a('string').and.not.empty;\r",
                  "});\r",
                  "pm.test(\"User object returned\", () => {\r",
                  "  const b = pm.response.json();\r",
                  "  pm.expect(b.user).to.have.property('id');\r",
                  "  pm.expect(b.user).to.not.have.property('password');\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"name\": \"Test User\",\r\n  \"email\": \"testuser@test.com\",\r\n  \"password\": \"password123\"\r\n}",
