# ─── Node ───────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Environment files ──────────────────────────────────
.env
.env.local
.env.development
.env.production
backend/.env
frontend/.env

# ─── Build outputs ──────────────────────────────────────
dist/
build/
frontend/dist/

# ─── Prisma ─────────────────────────────────────────────
# Keep migrations/ in git — they are version-controlled schema history
# but ignore the generated client (regenerated on each npm install)
backend/node_modules/

# ─── Uploads ────────────────────────────────────────────
# User-uploaded images should NOT be in git
backend/uploads/*
!backend/uploads/.gitkeep

# ─── Docker ─────────────────────────────────────────────
# Docker volumes are local; docker-compose.yml IS committed
docker-volumes/

# ─── OS files ───────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
*.swp
*.swo

# ─── IDE ────────────────────────────────────────────────
.vscode/settings.json
.idea/

# ─── Logs ───────────────────────────────────────────────
*.log
logs/