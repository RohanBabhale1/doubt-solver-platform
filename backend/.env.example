# ─── Database ──────────────────────────────────────────
# For local development (without Docker): use localhost
# For Docker Compose: the service name 'postgres' is the host
DATABASE_URL="postgresql://student:password123@localhost:5432/doubtsolverdb"

# ─── Redis ─────────────────────────────────────────────
# For local dev: redis://localhost:6379
# For Docker: redis://redis:6379
REDIS_URL="redis://localhost:6379"

# ─── Kafka ─────────────────────────────────────────────
# For local dev: localhost:9092  (or 9093 — the PLAINTEXT_HOST listener)
# For Docker: kafka:9092         (PLAINTEXT internal listener)
KAFKA_BROKER="localhost:9092"

# ─── JWT ───────────────────────────────────────────────
# Must be at least 32 characters. Change this before deploying.
JWT_SECRET="your_super_secret_jwt_key_change_this_min_32_characters"

# ─── Server ────────────────────────────────────────────
PORT=5000
NODE_ENV="development"

# ─── CORS ──────────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"